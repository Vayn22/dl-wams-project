FROM node:22-alpine

ENV NEXT_TELEMETRY_DISABLED=1

WORKDIR /app

COPY package*.json ./
RUN npm ci --include=dev

COPY . .

ARG NEXT_PUBLIC_AUTH_SERVICE_URL=http://auth.localhost:8080
ARG NEXT_PUBLIC_PATIENT_SERVICE_URL=http://patient.localhost:8080
ARG NEXT_PUBLIC_AI_SERVICE_URL=http://ai.localhost:8080

ENV NEXT_PUBLIC_AUTH_SERVICE_URL=${NEXT_PUBLIC_AUTH_SERVICE_URL}
ENV NEXT_PUBLIC_PATIENT_SERVICE_URL=${NEXT_PUBLIC_PATIENT_SERVICE_URL}
ENV NEXT_PUBLIC_AI_SERVICE_URL=${NEXT_PUBLIC_AI_SERVICE_URL}
ENV NODE_ENV=production

RUN npm run build

EXPOSE 3000

CMD ["npm", "run", "start", "--", "-H", "0.0.0.0", "-p", "3000"]
